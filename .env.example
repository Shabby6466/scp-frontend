# ─── Database ─────────────────────────────────────────────────────────
# Create DB: createdb school_compliance
# Homebrew/macOS often has no "postgres" user — use your OS username: psql -h localhost -p 5432 -c "\\du"
# With password: postgresql://USER:PASSWORD@localhost:5432/school_compliance
DATABASE_URL=postgresql://YOUR_OS_USERNAME@localhost:5432/school_compliance

# ─── JWT / Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# JWT expiration in seconds (e.g. 604800 = 7 days)
JWT_EXPIRATION=604800

# ─── File storage (documents) ─────────────────────────────────────────
# `supabase` (default) = Supabase Storage. `s3` = AWS S3 — same API, swap env only.
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key from Supabase Dashboard → Settings → API (server only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=documents

# When STORAGE_PROVIDER=s3, set these instead (or in addition if you switch back later):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name

# ─── MailerSend ───────────────────────────────────────────────────────
# Get your API key from https://www.mailersend.com/
MAILERSEND_API_KEY=your-mailersend-api-key
# Must be a verified sender domain/email in MailerSend
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=School System

# ─── URLs ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ─── Backend ──────────────────────────────────────────────────────────
PORT=4000
