generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DIRECTOR
  BRANCH_DIRECTOR
  TEACHER
  STUDENT
}

enum StaffPosition {
  ED_DIRECTOR
  LEAD_TEACHER
  ASSISTANT_TEACHER
  PARAPROFESSIONAL
}

enum RenewalPeriod {
  NONE
  ANNUAL
  BIENNIAL
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  password             String?
  name                 String?
  role                 UserRole
  authorities          UserRole[]         @default([])
  schoolId             String?
  branchId             String?
  assignedById         String?
  /** Teacher position at branch (no separate StaffProfile row). */
  staffPosition        StaffPosition?
  /** Cleared for active teaching after key documents verified. */
  staffClearanceActive Boolean            @default(false)
  emailVerifiedAt      DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  school               School?            @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  branch               Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedBy           User?              @relation("AuthorityAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedUsers        User[]             @relation("AuthorityAssignedBy")
  uploadedDocuments    Document[]         @relation("UploadedBy")
  ownerDocuments       Document[]         @relation("DocumentOwner")
  createdDocumentTypes DocumentType[] @relation("DocumentTypeCreator")
  requiredDocTypes      DocumentType[]     @relation("UserRequiredDocTypes")
  directorProfile       DirectorProfile?
  branchDirectorProfile BranchDirectorProfile?
  teacherProfile        TeacherProfile?
  studentProfile        StudentProfile?

  @@index([role])
  @@index([schoolId])
  @@index([branchId])
  @@index([assignedById])
}

model School {
  id            String       @id @default(cuid())
  name          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  users         User[]
  branches      Branch[]
  documentTypes DocumentType[]
}

model Branch {
  id            String         @id @default(cuid())
  name          String
  schoolId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users         User[]
  documentTypes DocumentType[]

  @@index([schoolId])
}

model DocumentType {
  id                 String           @id @default(cuid())
  name               String
  targetRole         UserRole
  isMandatory        Boolean          @default(true)
  renewalPeriod      RenewalPeriod    @default(NONE)
  sortOrder          Int              @default(0)
  schoolId           String?
  /** When set, this type is scoped to a branch (e.g. created by a branch director). Null = school-wide. */
  branchId           String?
  createdById        String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  school             School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  branch             Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy          User             @relation("DocumentTypeCreator", fields: [createdById], references: [id], onDelete: Restrict)
  requiredUsers      User[]           @relation("UserRequiredDocTypes")
  documents          Document[]

  @@index([schoolId])
  @@index([branchId])
  @@index([targetRole])
  @@index([createdById])
}

model Document {
  id             String           @id @default(cuid())
  ownerUserId    String
  documentTypeId String
  uploadedById   String
  s3Key          String
  fileName       String
  mimeType       String
  sizeBytes      Int
  issuedAt       DateTime?
  expiresAt      DateTime?
  verifiedAt     DateTime?
  createdAt      DateTime         @default(now())

  ownerUser      User             @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  uploadedBy     User             @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  documentType   DocumentType     @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)

  @@index([ownerUserId])
  @@index([documentTypeId])
  @@index([uploadedById])
  @@index([expiresAt])
  @@index([createdAt])
}

model DirectorProfile {
  userId      String   @id
  officePhone String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BranchDirectorProfile {
  userId           String   @id
  branchStartDate  DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  userId          String   @id
  subjectArea     String?
  employeeCode    String?
  joiningDate     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentProfile {
  userId        String   @id
  rollNumber    String?
  guardianName  String?
  guardianPhone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id                          String   @id @default("default")
  otpEmailVerificationEnabled Boolean  @default(true)
  selfRegistrationEnabled     Boolean  @default(true)
  updatedAt                   DateTime @updatedAt
}

model AuthOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}
